{
	"name": "mothmark",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"db:up": "\"$(brew --prefix postgresql@17)/bin/pg_ctl\" -D \"$(brew --prefix)/var/postgresql@17\" -l \"$(brew --prefix)/var/log/postgresql@17.log\" start",
		"db:down": "\"$(brew --prefix postgresql@17)/bin/pg_ctl\" -D \"$(brew --prefix)/var/postgresql@17\" stop",
		"db:create": "\"$(brew --prefix postgresql@17)/bin/createdb\" mothmark",
		"db:migrate": "pnpm migrate",
		"db:make": "node --env-file-if-exists=.env --import tsx db/createMigration.ts",
		"migrate": "node --env-file-if-exists=.env --import tsx db/migrate.ts",
		"build": "next build",
		"pages:build": "next build --webpack",
		"deploy": "pnpm pages:build && wrangler pages deploy out --project-name mothmark",
		"start": "next start",
		"lint": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"ts-check": "npx tsc --noEmit"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css,scss,md,mdx}": "prettier --write"
	},
	"dependencies": {
		"@types/jest": "^30.0.0",
		"knex": "^3.3.0",
		"lucide-react": "^1.23.0",
		"next": "16.2.9",
		"pg": "^8.22.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hotkeys-hook": "^5.3.3",
		"sass": "^1.101.0",
		"save-dev": "0.0.1-security",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.2.9",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.4",
		"tailwindcss": "^4",
		"ts-node": "^10.9.2",
		"tsx": "^4.23.1",
		"typescript": "^5",
		"wrangler": "^4.110.0"
	}
}
